{
  "$schema": "./node_modules/knip/schema.json",
  "workspaces": {
    "website": {
      "entry": [
        "src/pages/**/*.astro",
        "src/layouts/**/*.astro",
        "src/components/**/*.{astro,ts,tsx}"
      ],
      "project": ["src/**/*.{astro,ts,tsx,js,mjs,cjs}"],
      "ignoreDependencies": ["sanity", "prettier-plugin-astro"]
    },
    "studio": {
      "entry": ["schemaTypes/index.ts"],
      "project": ["**/*.{ts,tsx,js,mjs,cjs}"]
    }
  }
}
