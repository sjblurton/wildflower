    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@sanity/astro": "^3.3.1",
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "astro-portabletext": "^0.13.0",
    "chalk": "^5.6.2",
    "daisyui": "^5.5.19",
    "prettier-plugin-astro": "^0.14.1",
