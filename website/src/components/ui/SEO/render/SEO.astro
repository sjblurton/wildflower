---
import { sanityClient } from '../../../../lib/cms/sanity';
import { pageSeoBySlugQuery, siteSeoQuery } from '../data/seo.query';
import { loadSeoMetadata } from '../logic/SEO.logic';
import SeoShow from './SeoShow.astro';

interface Props {
  pageSlug?: string;
  pathname: string;
  fetchSeoSettings: () => Promise<unknown>;
  fetchPageSeoDocument: (slug: string) => Promise<unknown>;
}

const { pageSlug, pathname } = Astro.props as Props;
const meta = await loadSeoMetadata({ pageSlug, pathname, fetchSeoSettings: () => sanityClient.fetch(siteSeoQuery), fetchPageSeoDocument: (slug: string) => sanityClient.fetch(pageSeoBySlugQuery, { slug }) });
---

<SeoShow {...meta} />