---
import type { SanityImage as SanityImageType } from '../../../lib/schemas/shared/primitives';
import SanityImage from '../atoms/media/SanityImage/SanityImage.astro';

type Props = {
  images: SanityImageType[];
};

const { images } = Astro.props as Props;
---

<div class="carousel max-w-lg">
  {
    images.length === 1 ? (
      <SanityImage image={images[0]} class="w-full rounded-lg shadow-2xl" />
    ) : (
      images.map((image, index) => (
        <div id={`slide${index + 1}`} class="carousel-item relative w-full">
          <SanityImage image={image} class="w-full rounded-lg shadow-2xl" />
          <div class="absolute left-5 right-5 top-1/2 flex -translate-y-1/2 transform justify-between">
            <a href={`#slide${index === 0 ? images.length : index}`} class="btn btn-circle">
              ❮
            </a>
            <a href={`#slide${index === images.length - 1 ? 1 : index + 2}`} class="btn btn-circle">
              ❯
            </a>
          </div>
        </div>
      ))
    )
  }
</div>
