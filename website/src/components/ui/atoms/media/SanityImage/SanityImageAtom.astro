---
import type { SanityImage } from '../../../../../lib/schemas/shared/primitives'
import { buildSanityImageRenderData } from './sanityImage.logic'

interface Props {
  image?: SanityImage
  alt?: string
  class?: string
  width?: number
  height?: number
  sizes?: string
  quality?: number
  loading?: 'lazy' | 'eager'
  decoding?: 'async' | 'sync' | 'auto'
  fetchpriority?: 'high' | 'low' | 'auto'
}

const {
  image,
  alt,
  class: className = '',
  width = 1200,
  height,
  sizes,
  quality,
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
} = Astro.props

const {
  src,
  srcSet,
  sizes: resolvedSizes,
  altText,
} = buildSanityImageRenderData({
  image,
  alt,
  width,
  height,
  sizes,
  quality,
})
---

{src && (
  <img
    src={src}
    srcset={srcSet}
    sizes={resolvedSizes}
    alt={altText}
    class={className}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
  />
)}
