---
import { sanityClient } from '../../../lib/cms/sanity'
import { footerSettingsQuery } from './footer.query'
import { loadFooterSettings } from './footer.logic'
import FooterView from './FooterView.astro'

const footer = await loadFooterSettings({
	fetchFooterSettings: () => sanityClient.fetch(footerSettingsQuery),
	queryName: 'footerSettingsQuery',
})
---

<FooterView footer={footer} />
