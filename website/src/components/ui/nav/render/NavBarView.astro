---
import LogoLink from '../../atoms/LogoLink/LogoLink.astro';
import SanityImage from '../../atoms/media/SanityImage/SanityImage.astro';
import type { NavSettings } from '../data/nav.schema';

interface Props {
  nav: NavSettings;
}

const { nav } = Astro.props;
const links = Array.isArray(nav?.navLinks)
  ? nav.navLinks.filter(
      (link) =>
        link?.label?.trim() &&
        (link._type === 'urlLinkReference' ? link.url?.trim() : link.slug?.trim()),
    )
  : [];
const siteName = nav?.navSiteName?.trim() || null;
const hasLogo = Boolean(nav?.navLogo?.asset?._ref);
const hasLogoAlt = Boolean(nav?.navLogo?.alt?.trim());
const hasSiteName = Boolean(siteName);
const showFallbackName = !hasLogo && !hasSiteName;
---

<nav class={`navbar border-b bg-base-200 border-base-300 px-4`}>
  <div class="max-w-6xl flex flex-direction-row items-center justify-between w-full mx-auto">
    <div class="navbar-start gap-3">
      <div class="dropdown">
        <div tabindex="0" role="button" class="btn btn-ghost btn-circle">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h7"></path>
          </svg>
        </div>
        <ul
          tabindex="-1"
          class="menu menu-sm dropdown-content bg-base-100 rounded-box z-1 mt-3 w-52 p-2 shadow"
        >
          {
            links.map((link) => {
              const href = link._type === 'urlLinkReference' ? link.url : link.slug;
              return (
                <li>
                  <a href={href}>{link.label}</a>
                </li>
              );
            })
          }
        </ul>
      </div>
    </div>

    <div class="navbar-end">
      {
        showFallbackName ? (
          <LogoLink href="/" />
        ) : (
          <a href="/" class="font-semibold text-lg flex items-center gap-2">
            {hasLogo && (
              <SanityImage
                image={nav.navLogo}
                alt={hasLogoAlt ? nav.navLogo?.alt : (siteName ?? 'Wildflower')}
                class="h-8 w-auto"
                width={120}
              />
            )}
            {hasSiteName && <span>{siteName}</span>}
          </a>
        )
      }
    </div>
  </div>
</nav>
