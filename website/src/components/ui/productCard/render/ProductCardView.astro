---
import type { SanityImage as SanityImageType } from '../../../../lib/schemas/shared/primitives';
import SanityImage from '../../atoms/media/SanityImage/SanityImage.astro';
import type { CtaProps } from '../logic/ProductCard.logic';

export type ProductCardViewProps = {
  description: string;
  title: string;
  image?: SanityImageType | null;
  cta: CtaProps[] | null;
};

const { description, title, image, cta } = Astro.props as ProductCardViewProps;
---

<div class="card bg-base-100 w-80 shadow-sm">
  <figure>
    <SanityImage
      data-testid="sanity-image-product-card"
      image={image}
      class="w-80 block h-56 object-cover"
      loading="lazy"
      decoding="async"
    />
  </figure>
  <div class="card-body">
    <h2 class="card-title">{title}</h2>
    <p>{description}</p>
    <div class="card-actions justify-end">
      {
        cta &&
          cta.map(({ buttons }) =>
            buttons.map(({ label, url, class: className, icon, iconPosition }) => {
              if (icon?._type === 'image') {
                icon = (
                  <SanityImage
                    data-testid="sanity-image-product-card-icon"
                    image={icon}
                    class="w-4 h-4 inline-block mr-1"
                  />
                );
              } else if (icon?._type === 'internal') {
                icon = (
                  <span
                    data-testid="product-card-internal-icon"
                    class={`global-icon-colour w-4 h-4 inline-block mr-1`}
                    set:html={icon.link}
                  />
                );
              }

              return (
                <a href={url} type="button" class={className}>
                  {iconPosition === 'left' && icon}
                  {label}
                  {iconPosition === 'right' && icon}
                </a>
              );
            }),
          )
      }
    </div>
  </div>
</div>
