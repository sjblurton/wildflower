---
import { type ProductSection } from '../../../lib/schemas/sections/productsSection';
import { getTextClassNames } from '../../../styles/text-map';
import ProductCard from '../../ui/ProductCard/ProductCard.astro';
import { fetchLinkReference } from '../../../lib/links/fetchLinkReference';
import { BG_CLASS_MAPS } from '../../../styles/bg-maps';

export type Props = ProductSection;

const { products, title, alignTitle, backgroundColour } = Astro.props;
---

<section
  class=`flex justify-center overflow-hidden max-w-5xl mx-auto px-2 py-8 flex-col ${BG_CLASS_MAPS.COLOR[backgroundColour]}`
>
  {
    title && (
      <h2
        class={`text-3xl font-bold tracking-tight text-heading md:text-4xl lg:text-5xl mb-4 ${getTextClassNames({ align: alignTitle })}`}
      >
        {title}
      </h2>
    )
  }
  <div class="flex flex-wrap gap-6 justify-center items-stretch h-full">
    {
      products &&
        products.map((product) => (
          <ProductCard {...product} fetchLinkReference={fetchLinkReference} />
        ))
    }
  </div>
</section>
