---
import { z } from 'zod';
import Layout from '../layouts/Layout.astro';
import PageTemplate from '../components/templates/PageTemplate.astro';
import { pageBySlugQuery, pageSlugListQuery } from '../lib/cms/queries';
import { pageSchema, pageSlugListItemSchema } from '../lib/schemas/content/page';
import { sanityClient } from '../lib/cms/sanity';

export async function getStaticPaths() {
  const rawSlugs = await sanityClient.fetch(pageSlugListQuery);
  const slugItems = z.array(pageSlugListItemSchema).parse(rawSlugs);

  return slugItems.filter(({ slug }) => slug !== 'home').map(({ slug }) => ({ params: { slug } }));
}

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : slugParam;

if (!slug) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

const rawPage = await sanityClient.fetch(pageBySlugQuery, { slug });
const result = pageSchema.safeParse(rawPage);

if (!result.success) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

const page = result.data;
---

<Layout pageSlug={slug}>
  <PageTemplate page={page} />
</Layout>
